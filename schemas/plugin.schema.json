{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/seven332/codex-marketplace/schemas/plugin.schema.json",
  "title": "Codex Plugin Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "author",
    "skills",
    "interface"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "pattern": "^https://.+"
        }
      }
    },
    "homepage": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "skills": {
      "enum": [
        "./skills",
        "./skills/"
      ]
    },
    "apps": {
      "enum": [
        ".app.json",
        "./.app.json"
      ]
    },
    "mcpServers": {
      "oneOf": [
        {
          "enum": [
            ".mcp.json",
            "./.mcp.json"
          ]
        },
        {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        }
      ]
    },
    "interface": {
      "type": "object",
      "required": [
        "displayName",
        "shortDescription",
        "longDescription",
        "developerName",
        "category",
        "capabilities"
      ],
      "anyOf": [
        {
          "required": [
            "defaultPrompt"
          ]
        },
        {
          "required": [
            "default_prompt"
          ]
        }
      ],
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "shortDescription": {
          "type": "string",
          "minLength": 1
        },
        "longDescription": {
          "type": "string",
          "minLength": 1
        },
        "developerName": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "defaultPrompt": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "default_prompt": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "websiteURL": {
          "type": "string",
          "pattern": "^https://.+"
        },
        "privacyPolicyURL": {
          "type": "string",
          "pattern": "^https://.+"
        },
        "termsOfServiceURL": {
          "type": "string",
          "pattern": "^https://.+"
        },
        "brandColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "composerIcon": {
          "type": "string",
          "minLength": 1
        },
        "logo": {
          "type": "string",
          "minLength": 1
        },
        "screenshots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
